{
    "name": "aw-watcher-cursor",
    "displayName": "aw-watcher-cursor",
    "description": "Editor watcher for ActivityWatch, the free and open-source automated time tracker.",
    "version": "1.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/chenbaiyujason/aw-watcher-cursor"
    },
    "publisher": "activitywatch",
    "author": "ActivityWatch Developers",
    "bugs": {
        "url": "https://github.com/chenbaiyujason/aw-watcher-cursor/issues"
    },
    "engines": {
        "vscode": "^1.23.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "multi-root ready"
    ],
    "icon": "media/logo/logo.png",
    "activationEvents": [
        "*"
    ],
    "extensionKind": [
        "ui"
    ],
    "main": "./out/src/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.reload",
                "title": "Reload ActivityWatch"
            },
            {
                "command": "aw-watcher-vscode.showConnectionStatus",
                "title": "Show ActivityWatch Connection Status"
            },
            {
                "command": "aw-watcher-vscode.reconnect",
                "title": "Reconnect ActivityWatch"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "aw-watcher-vscode extension configuration",
            "properties": {
                "aw-watcher-vscode.maxHeartbeatsPerSec": {
                    "type": "number",
                    "default": 0.5,
                    "description": "Controls the maximum number of hearbeats sent per second."
                },
                "aw-watcher-vscode.pulseTimeSec": {
                    "type": "number",
                    "default": 30,
                    "description": "Legacy alias for fileActivityPulseTimeSec（向后兼容）。"
                },
                "aw-watcher-vscode.fileActivityPulseTimeSec": {
                    "type": "number",
                    "default": 30,
                    "description": "文件活动 heartbeat 的合并窗口（秒）。查看与编辑统一走此参数。"
                },
                "aw-watcher-vscode.textChangeDebounceMs": {
                    "type": "number",
                    "default": 750,
                    "description": "Debounces immediate text-change driven heartbeat refreshes."
                },
                "aw-watcher-vscode.enableCommitArchive": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable recording full git commit archive events."
                },
                "aw-watcher-vscode.commitBackfillCount": {
                    "type": "number",
                    "default": 20,
                    "description": "How many recent commits should be backfilled at startup."
                },
                "aw-watcher-vscode.includeAuthorPII": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include git author name and email in commit archive."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "postinstall": "node ./node_modules/vscode/bin/install",
        "test": "npm run compile && node ./node_modules/vscode/bin/test",
        "test:mocha": "npm run compile && node ./node_modules/mocha/bin/mocha \"./out/src/test/**/*.test.js\"",
        "vscode:prepublish": "npm run compile",
        "report:project": "npm run compile && node ./out/scripts/report-project.js",
        "report:agent": "npm run compile && node ./out/scripts/report-agent.js",
        "report:commits": "npm run compile && node ./out/scripts/report-commits.js",
        "push:test-timeline": "npm run compile && node ./out/scripts/push-test-timeline.js"
    },
    "devDependencies": {
        "@types/mocha": "^2.2.42",
        "@types/node": "^25.3.5",
        "@vscode/vsce": "^3.7.1",
        "mocha": "^8.2.1",
        "tslint": "^5.20.1",
        "typescript": "^5.9.3",
        "vscode": "^1.1.37"
    },
    "dependencies": {
        "axios": "^0.21.1"
    }
}